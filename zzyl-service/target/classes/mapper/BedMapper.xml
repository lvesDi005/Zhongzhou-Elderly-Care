<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzyl.mapper.BedMapper">
    <resultMap id="BedResultMap" type="com.zzyl.entity.Bed">
        <id column="id" property="id"/>
        <result column="bed_number" property="bedNumber"/>
        <result column="bed_status" property="bedStatus"/>
        <result column="room_id" property="roomId"/>
        <result property="sort" column="sort"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <resultMap id="BedVoResultMap" type="com.zzyl.vo.BedVo">
        <id column="id" property="id"/>
        <result column="bed_number" property="bedNumber"/>
        <result column="bed_status" property="bedStatus"/>
        <result column="room_id" property="roomId"/>
        <result property="sort" column="sort"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="lname" property="lname"/>
        <result column="ename" property="name"/>
        <result column="eid" property="elderId"/>
        <result column="price" property="price"/>
    </resultMap>
    <insert id="addBed">
        insert into bed(bed_number, bed_status, room_id, sort, create_by, update_by, remark, create_time, update_time)
        values (#{bedNumber}, #{bedStatus}, #{roomId}, #{sort}, #{createBy}, #{updateBy}, #{remark}, #{createTime}, #{updateTime})
    </insert>
    <update id="updateBed">
        update bed
        <set>
            <if test="bed.bedNumber != null">bed_number = #{bed.bedNumber},</if>
            <if test="bed.bedStatus != null">bed_status = #{bed.bedStatus},</if>
            <if test="bed.roomId != null">room_id = #{bed.roomId},</if>
            <if test="bed.sort != null">sort = #{bed.sort},</if>
            <if test="bed.updateBy != null">update_by = #{bed.updateBy},</if>
            <if test="bed.remark != null">remark = #{bed.remark},</if>
            <if test="bed.updateTime != null">update_time = #{bed.updateTime},</if>
        </set>
        where id = #{bed.id}
    </update>


    <select id="getBedsByRoomId" resultMap="BedVoResultMap" parameterType="java.lang.Long">
        select b.*,
               e.name  as ename,
               e.id    as eid
        from bed b
                 left join elder e on b.id = e.bed_id
        where b.room_id = #{roomId}
        order by b.sort, b.create_time desc
    </select>
    <select id="getBedById" resultMap="BedVoResultMap" parameterType="java.lang.Long">
        select b.*,
               e.name  as ename,
               e.id    as eid
        from bed b
                 left join elder e on b.id = e.bed_id
        where b.id = #{id}
    </select>
</mapper>
