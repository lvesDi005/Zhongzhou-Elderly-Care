<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzyl.mapper.NursingTaskMapper">
    <resultMap id="taskVoMap" type="com.zzyl.entity.NursingTask">
        <id column="id" property="id"/>
        <result column="nursing_id" property="nursingId"/>
        <result column="project_id" property="projectId"/>
        <result column="elder_id" property="elderId"/>
        <result column="bed_number" property="bedNumber"/>
        <result column="task_type" property="taskType"/>
        <result column="estimated_server_time" property="estimatedServerTime"/>
        <result column="mark" property="mark"/>
        <result column="cancel_reason" property="cancelReason"/>
        <result column="status" property="status"/>
        <result column="rel_no" property="relNo"/>
        <result column="task_image" property="taskImage"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="remark" property="remark"/>
        <result column="elder_name" property="elderName"/>
        <result column="project_name" property="projectName"/>
        <result column="nursing_name" property="nursingName"/>
        <result column="creator" property="creator"/>
    </resultMap>
    <select id="selectByPage" resultMap="taskVoMap">
        select t.*, e.name elder_name, np.name project_name, su.real_name nursing_name, su2.real_name creator
        from nursing_task t
        left join elder e on t.elder_id = e.id
        left join nursing_project np on t.project_id = np.id
        left join sys_user su on t.nursing_id = su.id
        left join sys_user su2 on t.create_by = su2.id
        <where>
            <if test="elderName != null and elderName != ''">
                and e.name like concat('%',#{elderName},'%')
            </if>
            <if test="status != null">
                and t.status = #{status}
            </if>
            <if test="planId != null">
                and t.plan_id = #{planId}
            </if>
            <if test="nurseId != null">
                and t.nursing_id = #{nurseId}
            </if>
            <if test="projectId != null">
                and t.project_id = #{projectId}
            </if>
            <if test="startTime != null and startTime != ''">
                and t.estimated_server_time &gt;= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                and t.estimated_server_time &lt;= #{endTime}
            </if>
        </where>
        order by t.create_time desc
    </select>
</mapper>
